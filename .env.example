# Autonoma environment variables
# Copy this file to .env and fill in your keys.
# The control surface loads .env automatically on startup via dotenv.

# Optional — Anthropic API key. Not required if you have Pi OAuth tokens
# (~/.pi/agent/auth.json) from running `pi auth login`.
ANTHROPIC_API_KEY=

# Required — Groq API key for message classification router
GROQ_API_KEY=
